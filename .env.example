# Prompt Score — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── AI APIs ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# Perplexity API (pay-as-you-go at perplexity.ai/api)
PERPLEXITY_API_KEY=your-perplexity-api-key

# ── Airtable ───────────────────────────────────────────────────────────────
# Base ID: found in your Airtable base URL (airtable.com/{BASE_ID}/...)
AIRTABLE_API_KEY=your-airtable-personal-access-token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ── Email ──────────────────────────────────────────────────────────────────
# Resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_your-resend-api-key
REPLY_TO_EMAIL=reports@promptscore.io
SENDER_NAME=Prompt Score

# ── Tally Forms ─────────────────────────────────────────────────────────────
# Personal access token from tally.so/me/settings/api
TALLY_API_KEY=tly-your-tally-api-key
# Form IDs from tally.so (embedded on landing page)
TALLY_STARTER_FORM_ID=Np4kKB
TALLY_PRO_FORM_ID=q4Y6xY
TALLY_AGENCY_FORM_ID=QKxLg8
TALLY_WEBHOOK_SECRET=your-tally-webhook-secret

# ── Stripe ────────────────────────────────────────────────────────────────────
# Payment links (create in Stripe Dashboard → Payments → Payment links)
STRIPE_STARTER_LINK=https://buy.stripe.com/your-starter-link
STRIPE_PRO_LINK=https://buy.stripe.com/your-pro-link
STRIPE_AGENCY_LINK=https://buy.stripe.com/your-agency-link
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Gemini ───────────────────────────────────────────────────────────────────
# Direct Gemini API key from aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Stripe Price IDs ─────────────────────────────────────────────────────────
# Found in Stripe Dashboard → Products → each price row
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_AGENCY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ── n8n ───────────────────────────────────────────────────────────────────────
# Base URL of your n8n instance (Railway, cloud, or self-hosted)
N8N_BASE_URL=https://your-n8n-instance.railway.app
# Full webhook URL for the free check endpoint (copy from n8n after activating)
N8N_FREE_CHECK_URL=https://your-n8n-instance.railway.app/webhook/free-check

# ── App ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
LOG_LEVEL=INFO
